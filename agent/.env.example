AGENT_HOST=0.0.0.0
AGENT_PORT=8787
AGENT_DATA_ROOT=./data
AGENT_SUMMARY_INTERVAL_SECONDS=15
AGENT_FRAME_QUEUE_SIZE=64
AGENT_VISION_DEDUPE_THRESHOLD=4

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

GCP_PROJECT=gen-lang-client-0799166632
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Summarization backend: "ollama" (local) or "vertex"
SUMMARIZER_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT_SECONDS=45

# Post-meeting content generation orchestration
CONTENT_GENERATION_ENABLED=true
CONTENT_GENERATION_API_BASE_URL=http://127.0.0.1:8000
CONTENT_GENERATION_TIMEOUT_SECONDS=30
